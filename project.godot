; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="2D Metroidvania Template"
config/description="A Hollow Knight-inspired Metroidvania template with tight combat, ability-gated exploration, NPCs, quests, and boss fights. Built for Summer Engine."
run/main_scene="res://scenes/rooms/room_01.tscn"
config/features=PackedStringArray("4.6")

[autoload]

EventBus="*res://scripts/autoloads/event_bus.gd"
AbilityManager="*res://scripts/autoloads/ability_manager.gd"
RoomManager="*res://scripts/autoloads/room_manager.gd"
GameManager="*res://scripts/autoloads/game_manager.gd"
QuestManager="*res://scripts/autoloads/quest_manager.gd"
SaveManager="*res://scripts/autoloads/save_manager.gd"
SceneTransition="*res://scripts/autoloads/scene_transition.gd"
JuiceManager="*res://scripts/systems/juice_manager.gd"
AudioManager="*res://scripts/autoloads/audio_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="2D Metroidvania Template"

